# VoicERA Server Configuration

# Server
VOICERA_SERVER_URL=https://your-server.onrender.com
VOICERA_WEBSOCKET_URL=wss://your-server.onrender.com
VOICERA_API_KEY=your-secret-key
SAMPLE_RATE=8000

# Vobiz Telephony (Indian PSTN)
VOBIZ_API_BASE=https://api.vobiz.in/v1
VOBIZ_AUTH_ID=
VOBIZ_AUTH_TOKEN=
VOBIZ_CALLER_ID=+91XXXXXXXXXX

# LLM Providers (use one or more)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# STT Providers
DEEPGRAM_API_KEY=

# TTS Providers
CARTESIA_API_KEY=

# Optional: Sarvam (Indian languages)
SARVAM_API_KEY=

# Optional: Bhashini (free government API, 22 Indian languages)
BHASHINI_API_KEY=
BHASHINI_SOCKET_URL=wss://dhruva-api.bhashini.gov.in

# Optional: Self-hosted AI4Bharat models
INDIC_STT_SERVER_URL=http://localhost:8001
INDIC_TTS_SERVER_URL=http://localhost:8002
